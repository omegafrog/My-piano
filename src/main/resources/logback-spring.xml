<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="mypiano"/>
    <springProperty scope="context" name="ENV" source="spring.profiles.active" defaultValue="unknown"/>

    <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"app":"${APP_NAME}","env":"${ENV}"}</customFields>
            <includeMdc>true</includeMdc>
            <includeKeyValuePairs>true</includeKeyValuePairs>
            <includeStructuredArguments>true</includeStructuredArguments>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE_JSON"/>
    </root>
</configuration>
